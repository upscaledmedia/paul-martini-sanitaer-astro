---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  schema?: object;
}
const { title, description = 'Ihr Sanitär & Heizungsbauer in Mayen. Familienbetrieb in 3. Generation.', schema } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  "name": "Paul Martini Sanitär · Heizung · Klima",
  "description": "SHK-Familienbetrieb in 3. Generation aus Kehrig bei Mayen",
  "url": siteUrl,
  "telephone": "+4926514019589",
  "email": "basti.martini@web.de",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Polcher Str. 29A",
    "addressLocality": "Kehrig",
    "postalCode": "56729",
    "addressCountry": "DE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 50.3542,
    "longitude": 7.2431
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "07:45",
      "closes": "16:00"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "15"
  }
};
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/og-default.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(schema ?? localBusinessSchema)} />
  <slot name="head" />
</head>
<body class="bg-white">
  <!-- Skip to content (WCAG 2.1 AA) -->
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[var(--color-primary)] focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:font-semibold focus:text-sm">
    Zum Hauptinhalt springen
  </a>

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white border-b border-[var(--color-border)] shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-full bg-[var(--color-primary)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <div>
            <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-secondary)] text-base lg:text-lg leading-tight">Paul Martini</div>
            <div class="text-xs text-[var(--color-text-muted)] hidden sm:block">Sanitär · Heizung · Klima</div>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-6" aria-label="Hauptnavigation">
          <a href="/leistungen/" class="text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">Leistungen</a>
          <a href="/ueber-uns/" class="text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">Über uns</a>
          <a href="/standorte/sanitaer-polch/" class="text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">Polch</a>
          <a href="/karriere/" class="text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">Karriere</a>
          <a href="/kontakt/" class="text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">Kontakt</a>
        </nav>

        <!-- CTA Phone -->
        <div class="flex items-center gap-3">
          <a href="tel:+4926514019589" class="hidden sm:flex items-center gap-2 bg-[var(--color-primary)] text-white px-4 py-2 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            02651 4019589
          </a>
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="lg:hidden p-2 text-[var(--color-text)]" aria-label="Menü öffnen" aria-expanded="false">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
          </button>
        </div>
      </div>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-white">
      <div class="px-4 py-4 space-y-3">
        <a href="/leistungen/" class="block text-sm font-medium text-[var(--color-text)] py-2">Leistungen</a>
        <a href="/ueber-uns/" class="block text-sm font-medium text-[var(--color-text)] py-2">Über uns</a>
        <a href="/standorte/sanitaer-polch/" class="block text-sm font-medium text-[var(--color-text)] py-2">Polch</a>
        <a href="/karriere/" class="block text-sm font-medium text-[var(--color-text)] py-2">Karriere</a>
        <a href="/kontakt/" class="block text-sm font-medium text-[var(--color-text)] py-2">Kontakt</a>
        <a href="tel:+4926514019589" class="flex items-center gap-2 bg-[var(--color-primary)] text-white px-4 py-3 rounded-lg font-semibold text-sm justify-center">
          Jetzt anrufen: 02651 4019589
        </a>
      </div>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-[var(--color-section-dark)] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Company -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-full bg-[var(--color-primary)] flex items-center justify-center flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            </div>
            <div>
              <div style="font-family: var(--font-heading); font-weight: 700;" class="text-white">Paul Martini</div>
              <div class="text-xs text-gray-400">Sanitär · Heizung · Klima</div>
            </div>
          </div>
          <address class="not-italic text-sm text-gray-300 space-y-1">
            <p>Polcher Str. 29A</p>
            <p>56729 Kehrig bei Mayen</p>
          </address>
        </div>

        <!-- Kontakt -->
        <div>
          <h3 style="font-family: var(--font-heading);" class="font-semibold text-white mb-4 text-base">Kontakt</h3>
          <div class="space-y-2 text-sm text-gray-300">
            <p><a href="tel:+4926514019589" class="hover:text-[var(--color-primary-light)] transition-colors text-gray-300">02651 4019589</a></p>
            <p><a href="mailto:basti.martini@web.de" class="hover:text-[var(--color-primary-light)] transition-colors text-gray-300">basti.martini@web.de</a></p>
            <p>Mo–Fr: 7:45–16:00 Uhr</p>
          </div>
        </div>

        <!-- Links -->
        <div>
          <h3 style="font-family: var(--font-heading);" class="font-semibold text-white mb-4 text-base">Leistungen</h3>
          <ul class="space-y-2 text-sm text-gray-300">
            <li><a href="/leistungen/heizung-mayen/" class="hover:text-[var(--color-primary-light)] transition-colors">Heizung &amp; Wärmepumpe</a></li>
            <li><a href="/leistungen/badezimmersanierung-mayen/" class="hover:text-[var(--color-primary-light)] transition-colors">Badsanierung</a></li>
            <li><a href="/leistungen/klimatechnik-mayen/" class="hover:text-[var(--color-primary-light)] transition-colors">Klimatechnik</a></li>
            <li><a href="/leistungen/notdienst-reparaturen/" class="hover:text-[var(--color-primary-light)] transition-colors">Notdienst</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-gray-700 mt-10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-gray-400">
        <p>© {new Date().getFullYear()} Paul Martini Sanitär · Heizung · Klima</p>
        <div class="flex gap-4">
          <a href="/impressum/" class="hover:text-gray-200 transition-colors">Impressum</a>
          <a href="/datenschutz/" class="hover:text-gray-200 transition-colors">Datenschutz</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Sticky Mobile Phone Button -->
  <a href="tel:+4926514019589" class="fixed bottom-4 right-4 z-50 sm:hidden bg-[var(--color-primary)] text-white rounded-full p-4 shadow-lg hover:bg-[var(--color-primary-dark)] transition-colors" aria-label="Jetzt anrufen">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
  </a>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      const open = menu?.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    });
  </script>
</body>
</html>
