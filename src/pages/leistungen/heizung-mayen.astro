---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Heizung & Wärmepumpe Mayen | Paul Martini Sanitär"
  description="Heizungsinstallation, Wärmepumpen und Heizungssanierung in Mayen & Umgebung. Fachbetrieb aus Kehrig. Jetzt Angebot anfordern: 02651 4019589"
>

  <!-- Hero -->
  <section class="bg-[var(--color-section-dark)] py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-[var(--color-primary-light)] transition-colors">Startseite</a></li>
          <li aria-hidden="true" class="text-gray-600">›</li>
          <li><a href="/leistungen/" class="hover:text-[var(--color-primary-light)] transition-colors">Leistungen</a></li>
          <li aria-hidden="true" class="text-gray-600">›</li>
          <li class="text-gray-200" aria-current="page">Heizung &amp; Wärmepumpe</li>
        </ol>
      </nav>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wide mb-3">Mayen &amp; Umgebung</p>
          <h1 class="text-white mb-6">Heizung &amp; Wärmepumpe — modern &amp; effizient</h1>
          <p class="text-gray-300 text-lg leading-relaxed mb-8">
            Als SHK-Fachbetrieb aus Kehrig planen, installieren und warten wir Ihre Heizungsanlage.
            Von der Wärmepumpe bis zur Gas-Heizung — ehrliche Beratung, faire Preise.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/kontakt/" class="bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors text-center">
              Kostenlos anfragen
            </a>
            <a href="tel:+4926514019589" class="border-2 border-white text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-white hover:text-[var(--color-secondary)] transition-colors text-center">
              02651 4019589
            </a>
          </div>
        </div>
        <div class="hidden lg:flex justify-center">
          <div class="w-72 h-72 bg-[var(--color-secondary-light)] rounded-full flex items-center justify-center border-4 border-[var(--color-primary)]">
            <svg width="120" height="120" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true">
              <path d="M12 2c-4.97 0-9 4.03-9 9 0 2.39.88 4.57 2.33 6.25L4 20h5v-3H7.5C6.56 15.78 6 14.45 6 13c0-3.31 2.69-6 6-6s6 2.69 6 6c0 1.45-.56 2.78-1.5 3.78V20h5l-1.33-2.75C21.12 15.57 22 13.39 22 11c0-4.97-4.03-9-9-9zM9 21h6v-2H9v2z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Grid -->
  <section class="py-14 bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center mb-10">Was wir für Ihre Heizung tun</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'M12 2c-4.97 0-9 4.03-9 9 0 2.39.88 4.57 2.33 6.25L4 20h5v-3H7.5C6.56 15.78 6 14.45 6 13c0-3.31 2.69-6 6-6s6 2.69 6 6c0 1.45-.56 2.78-1.5 3.78V20h5l-1.33-2.75C21.12 15.57 22 13.39 22 11c0-4.97-4.03-9-9-9zM9 21h6v-2H9v2z', title: 'Wärmepumpeninstallation', desc: 'Luft-Wasser oder Erdwärme — wir planen und installieren effiziente Wärmepumpen für Neubau und Sanierung.' },
          { icon: 'M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z', title: 'Heizungswartung', desc: 'Regelmäßige Wartung verlängert die Lebensdauer und sichert den effizienten Betrieb Ihrer Anlage.' },
          { icon: 'M19.63 3.65l-1.41-1.42-1.45 1.45A9 9 0 003 12c0 4.97 4.03 9 9 9s9-4.03 9-9a9 9 0 00-1.37-4.77l-1.45 1.45A6.97 6.97 0 0119 12c0 3.87-3.13 7-7 7s-7-3.13-7-7a7 7 0 019.63-6.53l1.41-1.42A9.03 9.03 0 0012 3a9 9 0 00-2.37.35l1.41 1.42A7.04 7.04 0 0112 5c2.76 0 5.24 1.6 6.45 4.05l1.45-1.45A8.97 8.97 0 0012 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-2.13-.74-4.08-1.97-5.62l1.42-1.41z', title: 'Heizungsmodernisierung', desc: 'Alte Öl- oder Gas-Heizung tauschen und Energie sparen. Wir finden die wirtschaftlichste Lösung.' },
          { icon: 'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z', title: 'Notfallreparatur', desc: 'Heizung ausgefallen? Wir kommen schnell und reparieren zuverlässig — auch in dringenden Situationen.' },
          { icon: 'M11.5 2C6.81 2 3 5.81 3 10.5S6.81 19 11.5 19h.5v3c4.86-2.34 8-7 8-11.5C20 5.81 16.19 2 11.5 2zm1 14.5h-2v-2h2v2zm0-4h-2c0-3.25 3-3 3-5 0-1.1-.9-2-2-2s-2 .9-2 2h-2c0-2.21 1.79-4 4-4s4 1.79 4 4c0 2.5-3 2.75-3 5z', title: 'Fachkundige Beratung', desc: 'Wir erklären Ihre Optionen verständlich — ohne Fachjargon, ohne Verkaufsdruck, mit echter Empfehlung.' },
        ].map(item => (
          <div class="bg-white rounded-xl p-6 border border-[var(--color-border)] shadow-sm">
            <div class="w-12 h-12 bg-[var(--color-primary)] bg-opacity-10 rounded-lg flex items-center justify-center mb-4">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d={item.icon}/></svg>
            </div>
            <h3 class="text-[var(--color-secondary)] mb-2 text-base">{item.title}</h3>
            <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose-like space-y-8">
        <div>
          <h2 class="mb-4">Heizungsbau in Mayen — was wir bieten</h2>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Als SHK-Fachbetrieb aus Kehrig bei Mayen sind wir Ihr regionaler Partner für alle Heizungsthemen.
            Ob Neubau, Sanierung oder Wartung — wir kennen die lokalen Anforderungen und arbeiten zuverlässig und termingerecht.
          </p>
        </div>
        <div>
          <h2 class="mb-4">Wärmepumpe — die zukunftssichere Heizung</h2>
          <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
            Wärmepumpen nutzen die kostenlose Energie aus Luft, Erde oder Wasser und sind besonders effizient.
            Als Fachbetrieb beraten wir Sie, welche Wärmepumpe für Ihr Gebäude sinnvoll ist — und welche nicht.
          </p>
          <ul class="space-y-2 text-[var(--color-text-muted)] text-sm">
            <li class="flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" class="flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Luft-Wasser-Wärmepumpen für Bestandsgebäude</li>
            <li class="flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" class="flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Erdwärmepumpen für Neubauten und Sanierungen</li>
            <li class="flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" class="flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Kombination mit Photovoltaik möglich</li>
            <li class="flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" class="flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Fördermittel-Beratung (BEG, BAFA)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process — numbered timeline -->
  <section class="py-16 bg-[var(--color-surface)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center mb-12">So läuft Ihr Heizungsprojekt ab</h2>
      <div class="space-y-6">
        {[
          { step: '01', title: 'Kostenloser Ersttermin', desc: 'Wir besichtigen Ihr Objekt, hören zu und nehmen uns Zeit für Ihre Fragen. Kein Druck, kein Verkaufsgespräch.' },
          { step: '02', title: 'Planung &amp; Angebot', desc: 'Wir erstellen ein detailliertes, transparentes Angebot — mit allen Kosten auf einen Blick.' },
          { step: '03', title: 'Installation &amp; Montage', desc: 'Termingerechte Ausführung durch unser erfahrenes Fachteam. Sauber und störungsarm.' },
          { step: '04', title: 'Einweisung &amp; Nachbetreuung', desc: 'Wir erklären die Bedienung und stehen danach jederzeit für Fragen und Wartung zur Verfügung.' },
        ].map(item => (
          <div class="flex gap-6 bg-white rounded-xl p-6 border border-[var(--color-border)] shadow-sm">
            <div class="flex-shrink-0 w-12 h-12 bg-[var(--color-primary)] rounded-full flex items-center justify-center text-white font-bold text-sm">
              {item.step}
            </div>
            <div>
              <h3 class="text-[var(--color-secondary)] mb-1 text-base" set:html={item.title}></h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center mb-10">Häufige Fragen zur Heizung</h2>
      <div class="space-y-3">
        {[
          { q: 'Lohnt sich eine Wärmepumpe für mein Haus?', a: 'Eine Wärmepumpe lohnt sich besonders bei gut gedämmten Gebäuden und wenn eine Fußbodenheizung vorhanden ist. Wir beraten Sie ehrlich, ob es für Ihr Haus wirklich sinnvoll ist.' },
          { q: 'Wie lange dauert eine Heizungsinstallation?', a: 'Ein Heizungstausch dauert in der Regel 1–3 Tage. Bei aufwendigen Wärmepumpeninstallationen kann es etwas länger dauern. Wir planen mit Ihnen einen realistischen Zeitrahmen.' },
          { q: 'Welche Förderungen gibt es für neue Heizungen?', a: 'Für Wärmepumpen und andere erneuerbare Heizsysteme gibt es Bundesförderung (BEG) über die KfW und BAFA. Wir unterstützen Sie gerne bei der Antragstellung.' },
          { q: 'Wie oft sollte ich meine Heizung warten lassen?', a: 'Wir empfehlen eine jährliche Wartung. Das verlängert die Lebensdauer, sichert die Effizienz und ist oft Voraussetzung für Garantieleistungen des Herstellers.' },
        ].map(item => (
          <details class="bg-white border border-[var(--color-border)] rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[var(--color-secondary)] text-sm select-none">
              <span>{item.q}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0 text-[var(--color-primary)] group-open:rotate-180 transition-transform" aria-hidden="true"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
            </summary>
            <div class="px-5 pb-5 text-[var(--color-text-muted)] text-sm leading-relaxed border-t border-[var(--color-border)] pt-4">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-12 bg-[var(--color-surface-alt)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-center text-[var(--color-secondary)] mb-8 text-lg font-semibold">Weitere Leistungen</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/leistungen/badezimmersanierung-mayen/" class="bg-white rounded-xl p-5 border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors flex items-center gap-3">
          <div class="w-10 h-10 bg-[var(--color-surface)] rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1A2733" aria-hidden="true"><path d="M7 6h2v2H7V6zm4 0h2v2h-2V6zm4 0h2v2h-2V6zM5 4h14c1.1 0 2 .9 2 2v6H3V6c0-1.1.9-2 2-2zm16 9H3l1 9h16l1-9z"/></svg>
          </div>
          <span class="font-medium text-[var(--color-text)] text-sm">Badsanierung</span>
        </a>
        <a href="/leistungen/klimatechnik-mayen/" class="bg-white rounded-xl p-5 border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors flex items-center gap-3">
          <div class="w-10 h-10 bg-[var(--color-surface)] rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z"/></svg>
          </div>
          <span class="font-medium text-[var(--color-text)] text-sm">Klimatechnik</span>
        </a>
        <a href="/leistungen/notdienst-reparaturen/" class="bg-white rounded-xl p-5 border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors flex items-center gap-3">
          <div class="w-10 h-10 bg-[var(--color-surface)] rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1A2733" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          </div>
          <span class="font-medium text-[var(--color-text)] text-sm">Notdienst</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[var(--color-primary)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-white mb-4">Neue Heizung oder Wartung?</h2>
      <p class="text-orange-100 mb-8">Rufen Sie uns an — wir beraten Sie kostenlos und kommen zu Ihnen.</p>
      <a href="tel:+4926514019589" class="bg-white text-[var(--color-secondary)] px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-colors inline-block">
        02651 4019589 anrufen
      </a>
    </div>
  </section>

</BaseLayout>
