---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Leistungen | Paul Martini Sanitär · Heizung · Klima Mayen"
  description="Heizung, Badsanierung, Klimatechnik und Notdienst aus Kehrig bei Mayen. SHK-Familienbetrieb in 3. Generation. Jetzt anfragen!"
>

  <!-- Hero -->
  <section class="bg-[var(--color-section-dark)] py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-[var(--color-primary-light)] transition-colors">Startseite</a></li>
          <li aria-hidden="true" class="text-gray-600">›</li>
          <li class="text-gray-200" aria-current="page">Leistungen</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wide mb-3">SHK-Fachbetrieb</p>
        <h1 class="text-white mb-6">Unsere Leistungen</h1>
        <p class="text-gray-300 text-lg leading-relaxed">
          Von der Heizungsanlage über das Traumbad bis zur Klimaanlage und dem Notdienst — wir lösen Ihre Aufgaben professionell und persönlich.
        </p>
      </div>
    </div>
  </section>

  <!-- 4 Large Service Cards -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">

        <!-- Heizung -->
        <div class="bg-white rounded-2xl border border-[var(--color-border)] shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <div class="grid lg:grid-cols-3 gap-0">
            <div class="lg:col-span-1 bg-[var(--color-section-dark)] flex items-center justify-center p-12">
              <div class="text-center">
                <div class="w-20 h-20 bg-[var(--color-primary)] rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                    <path d="M12 2c-4.97 0-9 4.03-9 9 0 2.39.88 4.57 2.33 6.25L4 20h5v-3H7.5C6.56 15.78 6 14.45 6 13c0-3.31 2.69-6 6-6s6 2.69 6 6c0 1.45-.56 2.78-1.5 3.78V20h5l-1.33-2.75C21.12 15.57 22 13.39 22 11c0-4.97-4.03-9-9-9zM9 21h6v-2H9v2z"/>
                  </svg>
                </div>
                <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wide">Leistung 01</p>
              </div>
            </div>
            <div class="lg:col-span-2 p-8 lg:p-10">
              <h2 class="text-[var(--color-secondary)] mb-3 text-2xl">Heizung &amp; Wärmepumpe</h2>
              <p class="text-[var(--color-text-muted)] mb-5 leading-relaxed">
                Moderne Heizungsanlagen, Wärmepumpen, Sanierung alter Systeme, Wartung und Notfallreparatur.
                Wir beraten Sie ehrlich zur effizientesten Lösung für Ihr Zuhause.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                {['Wärmepumpe', 'Gas-Heizung', 'Pelletheizung', 'Wartung', 'Modernisierung'].map(tag => (
                  <span class="bg-[var(--color-surface)] text-[var(--color-text-muted)] text-xs px-3 py-1 rounded-full border border-[var(--color-border)]">{tag}</span>
                ))}
              </div>
              <a href="/leistungen/heizung-mayen/" class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors">
                Mehr erfahren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Badsanierung -->
        <div class="bg-white rounded-2xl border border-[var(--color-border)] shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <div class="grid lg:grid-cols-3 gap-0">
            <div class="lg:col-span-2 p-8 lg:p-10 order-2 lg:order-1">
              <h2 class="text-[var(--color-secondary)] mb-3 text-2xl">Badsanierung</h2>
              <p class="text-[var(--color-text-muted)] mb-5 leading-relaxed">
                Ihr altes Bad wird zum Wohlfühlraum. Von der Planung über Fliesen, Sanitär und Elektrik
                bis zur Fertigstellung — alles aus einer Hand. Kein Stress, kein Koordinationsaufwand.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                {['Komplettbad', 'Duschumbau', 'Barrierefrei', 'Planung', 'Fliesen'].map(tag => (
                  <span class="bg-[var(--color-surface)] text-[var(--color-text-muted)] text-xs px-3 py-1 rounded-full border border-[var(--color-border)]">{tag}</span>
                ))}
              </div>
              <a href="/leistungen/badezimmersanierung-mayen/" class="inline-flex items-center gap-2 bg-[var(--color-secondary)] text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-secondary-light)] transition-colors">
                Mehr erfahren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </a>
            </div>
            <div class="lg:col-span-1 bg-[var(--color-secondary)] flex items-center justify-center p-12 order-1 lg:order-2">
              <div class="text-center">
                <div class="w-20 h-20 bg-[var(--color-secondary-light)] rounded-full flex items-center justify-center mx-auto mb-4 border-2 border-[var(--color-primary)]">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                    <path d="M7 6h2v2H7V6zm4 0h2v2h-2V6zm4 0h2v2h-2V6zM5 4h14c1.1 0 2 .9 2 2v6H3V6c0-1.1.9-2 2-2zm16 9H3l1 9h16l1-9z"/>
                  </svg>
                </div>
                <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wide">Leistung 02</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Klimatechnik -->
        <div class="bg-white rounded-2xl border border-[var(--color-border)] shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <div class="grid lg:grid-cols-3 gap-0">
            <div class="lg:col-span-1 bg-[var(--color-section-dark)] flex items-center justify-center p-12">
              <div class="text-center">
                <div class="w-20 h-20 bg-[var(--color-primary)] rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                    <path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z"/>
                  </svg>
                </div>
                <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wide">Leistung 03</p>
              </div>
            </div>
            <div class="lg:col-span-2 p-8 lg:p-10">
              <h2 class="text-[var(--color-secondary)] mb-3 text-2xl">Klimatechnik</h2>
              <p class="text-[var(--color-text-muted)] mb-5 leading-relaxed">
                Klimaanlagen für Wohnräume, Büros und Gewerbe. Split-Systeme, Planung, Installation und Wartung.
                Angenehme Temperaturen im Sommer, effizientes Heizen im Winter.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                {['Split-Klimaanlage', 'Wärmepumpe Luft', 'Planung', 'Wartung', 'Gewerbe'].map(tag => (
                  <span class="bg-[var(--color-surface)] text-[var(--color-text-muted)] text-xs px-3 py-1 rounded-full border border-[var(--color-border)]">{tag}</span>
                ))}
              </div>
              <a href="/leistungen/klimatechnik-mayen/" class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors">
                Mehr erfahren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Notdienst -->
        <div class="bg-white rounded-2xl border border-[var(--color-border)] shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <div class="grid lg:grid-cols-3 gap-0">
            <div class="lg:col-span-2 p-8 lg:p-10 order-2 lg:order-1">
              <h2 class="text-[var(--color-secondary)] mb-3 text-2xl">Notdienst &amp; Reparaturen</h2>
              <p class="text-[var(--color-text-muted)] mb-5 leading-relaxed">
                Heizungsausfall, Rohrbruch oder defekte Sanitäranlage? Wir sind schnell vor Ort.
                Als lokaler Betrieb haben wir kurze Anfahrtswege und reagieren zügig auf Notfälle.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                {['Heizungsausfall', 'Rohrbruch', 'Schnellreparatur', 'Vor-Ort-Service', 'Lokal'].map(tag => (
                  <span class="bg-[var(--color-surface)] text-[var(--color-text-muted)] text-xs px-3 py-1 rounded-full border border-[var(--color-border)]">{tag}</span>
                ))}
              </div>
              <a href="/leistungen/notdienst-reparaturen/" class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors">
                Mehr erfahren
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </a>
            </div>
            <div class="lg:col-span-1 bg-[var(--color-primary)] flex items-center justify-center p-12 order-1 lg:order-2">
              <div class="text-center">
                <div class="w-20 h-20 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4 border-2 border-white">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                    <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
                  </svg>
                </div>
                <p class="text-white font-semibold text-sm uppercase tracking-wide">Leistung 04</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="mb-4">Welche Leistung benötigen Sie?</h2>
      <p class="text-[var(--color-text-muted)] mb-8 text-lg">Rufen Sie uns an — wir beraten Sie kostenlos und unverbindlich.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+4926514019589" class="bg-[var(--color-primary)] text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-[var(--color-primary-dark)] transition-colors">
          02651 4019589 anrufen
        </a>
        <a href="/kontakt/" class="border-2 border-[var(--color-secondary)] text-[var(--color-secondary)] px-8 py-4 rounded-xl font-bold text-lg hover:bg-[var(--color-secondary)] hover:text-white transition-colors text-center">
          Anfrage schreiben
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
