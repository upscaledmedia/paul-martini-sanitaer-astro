---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Sanitär & Heizung Polch | Paul Martini Sanitär"
  description="Ihr Sanitär- und Heizungsbauer für Polch und Umgebung. Paul Martini aus Kehrig — SHK-Familienbetrieb in 3. Generation. Jetzt anrufen: 02651 4019589"
>

  <!-- Hero -->
  <section class="bg-[var(--color-section-dark)] py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-[var(--color-primary-light)] transition-colors">Startseite</a></li>
          <li aria-hidden="true" class="text-gray-600">›</li>
          <li class="text-gray-200" aria-current="page">Sanitär Polch</li>
        </ol>
      </nav>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-[var(--color-primary)] bg-opacity-20 text-[var(--color-primary-light)] text-sm font-semibold px-4 py-2 rounded-full mb-6">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            Für Polch &amp; Umgebung
          </div>
          <h1 class="text-white mb-6">Ihr Sanitär &amp; Heizungsbauer für Polch</h1>
          <p class="text-gray-300 text-lg leading-relaxed mb-8">
            Als Familienbetrieb aus dem benachbarten Kehrig sind wir schnell in Polch vor Ort.
            Kurze Wege, persönlicher Kontakt, verlässliche Arbeit.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/kontakt/" class="bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors text-center">
              Jetzt anfragen
            </a>
            <a href="tel:+4926514019589" class="border-2 border-white text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-white hover:text-[var(--color-secondary)] transition-colors text-center">
              02651 4019589
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <div class="bg-[var(--color-secondary-light)] rounded-2xl p-8 border border-[var(--color-primary)] border-opacity-30">
            <h3 class="text-white mb-4 text-lg">Warum Martini für Polch?</h3>
            <ul class="space-y-3 text-sm text-gray-300">
              <li class="flex items-center gap-3"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Nur ~10 Minuten Anfahrt von Kehrig</li>
              <li class="flex items-center gap-3"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>5,0 Sterne Google-Bewertungen</li>
              <li class="flex items-center gap-3"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Familienbetrieb in 3. Generation</li>
              <li class="flex items-center gap-3"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Persönlicher Ansprechpartner</li>
              <li class="flex items-center gap-3"><svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Alle SHK-Leistungen aus einer Hand</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lokaler Bezug -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[var(--color-primary-text)] font-semibold text-sm uppercase tracking-wide mb-3">Lokal &amp; vertraut</p>
        <h2>Paul Martini für Polch — nah, zuverlässig, familiär</h2>
      </div>
      <p class="text-[var(--color-text-muted)] text-base leading-relaxed mb-4">
        Polch und Kehrig liegen keine 10 Kilometer auseinander. Das bedeutet für unsere Polcher Kunden:
        kurze Anfahrt, schnelle Reaktion, persönliche Betreuung ohne langen Koordinationsaufwand.
      </p>
      <p class="text-[var(--color-text-muted)] text-base leading-relaxed">
        Als Familienbetrieb in dritter Generation kennen wir viele Haushalte in der Region seit Jahren.
        Manche Kunden in Polch lassen sich schon seit Generationen von uns betreuen — das ist das Schönste, was wir uns vorstellen können.
      </p>
    </div>
  </section>

  <!-- Leistungen Grid -->
  <section class="py-14 bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center mb-10">Unsere Leistungen für Polch</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <a href="/leistungen/heizung-mayen/" class="group bg-white rounded-xl p-6 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all flex items-start gap-4">
          <div class="w-10 h-10 bg-[var(--color-primary)] bg-opacity-10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#E85000" class="group-hover:fill-white transition-colors" aria-hidden="true"><path d="M12 2c-4.97 0-9 4.03-9 9 0 2.39.88 4.57 2.33 6.25L4 20h5v-3H7.5C6.56 15.78 6 14.45 6 13c0-3.31 2.69-6 6-6s6 2.69 6 6c0 1.45-.56 2.78-1.5 3.78V20h5l-1.33-2.75C21.12 15.57 22 13.39 22 11c0-4.97-4.03-9-9-9zM9 21h6v-2H9v2z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-secondary)] mb-1 text-base">Heizung &amp; Wärmepumpe</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Neue Heizung oder Wartung — wir kommen schnell zu Ihnen nach Polch.</p>
          </div>
        </a>
        <a href="/leistungen/badezimmersanierung-mayen/" class="group bg-white rounded-xl p-6 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all flex items-start gap-4">
          <div class="w-10 h-10 bg-[var(--color-secondary)] bg-opacity-10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1A2733" class="group-hover:fill-white transition-colors" aria-hidden="true"><path d="M7 6h2v2H7V6zm4 0h2v2h-2V6zm4 0h2v2h-2V6zM5 4h14c1.1 0 2 .9 2 2v6H3V6c0-1.1.9-2 2-2zm16 9H3l1 9h16l1-9z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-secondary)] mb-1 text-base">Badsanierung</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Ihr Traumbad in Polch — von Planung bis Fertigstellung aus einer Hand.</p>
          </div>
        </a>
        <a href="/leistungen/klimatechnik-mayen/" class="group bg-white rounded-xl p-6 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all flex items-start gap-4">
          <div class="w-10 h-10 bg-[var(--color-primary)] bg-opacity-10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#E85000" class="group-hover:fill-white transition-colors" aria-hidden="true"><path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-secondary)] mb-1 text-base">Klimatechnik</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Klimaanlagen in Polch — Installation, Wartung und Reparatur.</p>
          </div>
        </a>
        <a href="/leistungen/notdienst-reparaturen/" class="group bg-white rounded-xl p-6 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-md transition-all flex items-start gap-4">
          <div class="w-10 h-10 bg-[var(--color-secondary)] bg-opacity-10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1A2733" class="group-hover:fill-white transition-colors" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          </div>
          <div>
            <h3 class="text-[var(--color-secondary)] mb-1 text-base">Notdienst &amp; Reparaturen</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Schnelle Hilfe im Notfall — direkt aus der Nachbarschaft.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Warum Martini -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[var(--color-primary-text)] font-semibold text-sm uppercase tracking-wide mb-3">Warum Martini?</p>
          <h2 class="mb-6">Das spricht für uns — in Polch wie überall</h2>
          <div class="space-y-3">
            {[
              'Kein Callcenter — Sie sprechen direkt mit Sebastian Martini',
              'Schnelle Reaktionszeit durch kurze Anfahrtswege',
              'Transparente Angebote ohne versteckte Kosten',
              'Familienbetrieb in 3. Generation — Vertrauen und Kontinuität',
              '5,0 Sterne bei Google — 15 zufriedene Kunden',
            ].map(item => (
              <div class="flex items-start gap-3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#E85000" class="flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span class="text-[var(--color-text-muted)] text-sm">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-[var(--color-surface)] rounded-2xl p-8 border border-[var(--color-border)]">
          <h3 class="text-[var(--color-secondary)] mb-4">Einzugsgebiet rund um Polch</h3>
          <div class="flex flex-wrap gap-2">
            {['Polch', 'Kehrig', 'Mayen', 'Rieden', 'Nitz', 'Thür', 'Münstermaifeld', 'Ochtendung', 'Weißenthurm', 'Andernach'].map(city => (
              <span class="bg-white border border-[var(--color-border)] text-[var(--color-text)] text-sm px-3 py-1 rounded-full">{city}</span>
            ))}
          </div>
          <div class="mt-6 pt-6 border-t border-[var(--color-border)]">
            <a href="/kontakt/" class="w-full bg-[var(--color-primary)] text-white py-3 rounded-lg font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors text-center block">
              Jetzt Termin anfragen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 bg-[var(--color-surface-alt)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center mb-10">Häufige Fragen aus Polch</h2>
      <div class="space-y-3">
        {[
          { q: 'Kommen Sie auch nach Polch?', a: 'Ja, selbstverständlich. Kehrig und Polch liegen nur ca. 10 km auseinander — wir sind regelmäßig in Polch und Umgebung tätig.' },
          { q: 'Wie schnell können Sie zu mir kommen?', a: 'Für reguläre Aufträge vereinbaren wir einen Termin mit Ihnen. Bei Notfällen versuchen wir so schnell wie möglich da zu sein.' },
          { q: 'Welche Leistungen bieten Sie in Polch an?', a: 'Alle unsere Leistungen: Heizung, Badsanierung, Klimatechnik und Notdienst. Als Vollsortiment-Betrieb lösen wir alle SHK-Aufgaben.' },
          { q: 'Gibt es einen festen Ansprechpartner?', a: 'Ja — Sie sprechen immer direkt mit Sebastian Martini oder seinem Team. Kein Callcenter, keine Weiterverbindungen.' },
        ].map(item => (
          <details class="bg-white border border-[var(--color-border)] rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[var(--color-secondary)] text-sm select-none">
              <span>{item.q}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0 text-[var(--color-primary)] group-open:rotate-180 transition-transform" aria-hidden="true"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
            </summary>
            <div class="px-5 pb-5 text-[var(--color-text-muted)] text-sm leading-relaxed border-t border-[var(--color-border)] pt-4">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[var(--color-primary)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-white mb-4">Ihr Handwerker für Polch — jetzt anfragen!</h2>
      <p class="text-orange-100 mb-8">Kostenlose Beratung, schneller Termin, persönliche Betreuung.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+4926514019589" class="bg-white text-[var(--color-secondary)] px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-colors">
          02651 4019589
        </a>
        <a href="/kontakt/" class="border-2 border-white text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white hover:text-[var(--color-primary)] transition-colors text-center">
          Nachricht schreiben
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
