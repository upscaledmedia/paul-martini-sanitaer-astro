---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Paul Martini Sanitär · Heizung · Klima | Mayen & Kehrig"
  description="Ihr SHK-Familienbetrieb in 3. Generation aus Kehrig bei Mayen. Heizung, Badsanierung, Klimatechnik & Notdienst. Jetzt anrufen: 02651 4019589"
>

  <!-- 1. HERO — Dark split layout -->
  <section class="bg-[var(--color-section-dark)] relative overflow-hidden">
    <!-- Orange geometric accent -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-5" aria-hidden="true">
      <div class="absolute top-10 right-10 w-96 h-96 rounded-full border-4 border-[var(--color-primary)]"></div>
      <div class="absolute bottom-10 right-32 w-64 h-64 rounded-full border-2 border-[var(--color-primary)]"></div>
    </div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[var(--color-primary)] opacity-10 rounded-tr-full" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text -->
        <div>
          <div class="inline-flex items-center gap-2 bg-[var(--color-primary)] bg-opacity-20 text-[var(--color-primary-light)] text-sm font-semibold px-4 py-2 rounded-full mb-6">
            <span class="w-2 h-2 rounded-full bg-[var(--color-primary)] inline-block"></span>
            Familienbetrieb seit 3 Generationen
          </div>
          <h1 class="text-white mb-6">
            Ihr Sanitär &amp;<br />
            <span class="text-[var(--color-primary)]">Heizungsbauer</span><br />
            in Mayen
          </h1>
          <p class="text-gray-300 text-lg mb-8 max-w-lg">
            Familienbetrieb in 3. Generation — persönlich, zuverlässig, nachhaltig.
            Sebastian Martini und sein Team stehen für echtes Handwerk aus der Region.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/kontakt/" class="bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold text-base hover:bg-[var(--color-primary-dark)] transition-colors text-center">
              Jetzt kostenlos anfragen
            </a>
            <a href="tel:+4926514019589" class="border-2 border-white text-white px-6 py-3 rounded-lg font-semibold text-base hover:bg-white hover:text-[var(--color-secondary)] transition-colors text-center">
              02651 4019589
            </a>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap gap-4 mt-10 pt-8 border-t border-gray-700">
            <div class="flex items-center gap-2 text-gray-300 text-sm">
              <span class="text-yellow-400 text-base">★★★★★</span>
              <span>5,0 Google</span>
            </div>
            <div class="w-px h-5 bg-gray-600 self-center"></div>
            <div class="text-gray-300 text-sm">3 Generationen</div>
            <div class="w-px h-5 bg-gray-600 self-center"></div>
            <div class="text-gray-300 text-sm">Notdienst verfügbar</div>
          </div>
        </div>

        <!-- Right: Orange accent card -->
        <div class="hidden lg:flex justify-center items-center">
          <div class="relative">
            <div class="w-80 h-96 bg-[var(--color-secondary-light)] rounded-2xl border-2 border-[var(--color-primary)] flex flex-col justify-center items-center p-8 text-center">
              <div class="w-16 h-16 bg-[var(--color-primary)] rounded-full flex items-center justify-center mb-4">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
              </div>
              <p class="text-[var(--color-primary)] font-semibold text-sm uppercase tracking-wide mb-2">Unser Service</p>
              <h3 class="text-white text-xl font-bold mb-4">Immer für Sie da</h3>
              <p class="text-gray-300 text-sm leading-relaxed">
                Von der Heizungsplanung über die Badsanierung bis zum Klimaservice —
                alles aus einer Hand, direkt und persönlich.
              </p>
              <div class="mt-6 pt-6 border-t border-gray-600 w-full text-center">
                <p class="text-[var(--color-primary)] font-bold text-lg">02651 4019589</p>
                <p class="text-gray-400 text-xs mt-1">Mo–Fr 7:45–16:00 Uhr</p>
              </div>
            </div>
            <!-- Decorative dots -->
            <div class="absolute -top-4 -right-4 w-24 h-24 opacity-30" aria-hidden="true">
              <div class="grid grid-cols-4 gap-1.5">
                {Array.from({length: 16}).map(() => (
                  <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)]"></div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. TRUST BAR — Orange/white stat cards -->
  <section class="bg-[var(--color-surface)] py-10 border-b border-[var(--color-border)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 flex items-center gap-4 shadow-sm border border-[var(--color-border)]">
          <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          </div>
          <div>
            <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-secondary)] text-2xl">5,0 Sterne</div>
            <div class="text-[var(--color-text-muted)] text-sm">15 Google-Bewertungen</div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 flex items-center gap-4 shadow-sm border border-[var(--color-border)]">
          <div class="w-12 h-12 bg-[var(--color-secondary)] rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
          </div>
          <div>
            <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-secondary)] text-2xl">3 Generationen</div>
            <div class="text-[var(--color-text-muted)] text-sm">Seit Jahrzehnten in der Region</div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 flex items-center gap-4 shadow-sm border border-[var(--color-border)]">
          <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <div>
            <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-secondary)] text-2xl">Kehrig → Mayen</div>
            <div class="text-[var(--color-text-muted)] text-sm">Nur 6 Minuten entfernt</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. ÜBER UNS TEASER — Left text, right orange border card -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[var(--color-primary-text)] font-semibold text-sm uppercase tracking-wide mb-3">Über uns</p>
          <h2 class="mb-6">Handwerk mit Herz — seit drei Generationen</h2>
          <p class="text-[var(--color-text-muted)] mb-4 text-base leading-relaxed">
            Was Franz-Josef Martini einst mit handwerklichem Können und Herzblut begann, führt heute Sebastian Martini in dritter Generation fort.
            Als SHK-Fachbetrieb aus Kehrig bei Mayen kennen wir unsere Region und unsere Kunden — viele davon seit Jahrzehnten.
          </p>
          <p class="text-[var(--color-text-muted)] mb-8 text-base leading-relaxed">
            Bei uns gibt es kein Callcenter, keine langen Warteschleifen. Sie erreichen uns direkt — und wir kommen zu Ihnen.
            Das ist Handwerk, wie es sein soll: persönlich, ehrlich, zuverlässig.
          </p>
          <a href="/ueber-uns/" class="inline-flex items-center gap-2 text-[var(--color-primary-text)] font-semibold hover:gap-3 transition-all">
            Mehr über uns
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
          </a>
        </div>

        <div class="relative">
          <div class="border-2 border-[var(--color-primary)] rounded-2xl p-8 bg-[var(--color-surface)]">
            <div class="flex items-start gap-3 mb-4">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#E85000" class="flex-shrink-0 mt-1" aria-hidden="true"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
              <div>
                <p class="text-[var(--color-text)] font-medium text-base italic leading-relaxed">
                  "Wir machen das, was wir können — und das ordentlich. Seit meinem Großvater ist das unser Anspruch, und daran hat sich nichts geändert."
                </p>
                <p class="text-[var(--color-primary-text)] font-semibold mt-3 text-sm">Sebastian Martini, Inhaber</p>
              </div>
            </div>
            <div class="mt-6 pt-6 border-t border-[var(--color-border)] grid grid-cols-3 gap-4 text-center">
              <div>
                <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-primary)] text-2xl">3.</div>
                <div class="text-[var(--color-text-muted)] text-xs">Generation</div>
              </div>
              <div>
                <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-primary)] text-2xl">5,0</div>
                <div class="text-[var(--color-text-muted)] text-xs">Google Sterne</div>
              </div>
              <div>
                <div style="font-family: var(--font-heading); font-weight: 800;" class="text-[var(--color-primary)] text-2xl">100%</div>
                <div class="text-[var(--color-text-muted)] text-xs">Persönlich</div>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-[var(--color-primary)] opacity-10 rounded-full -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. LEISTUNGEN GRID — 2x2 cards -->
  <section class="py-16 lg:py-24 bg-[var(--color-surface)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[var(--color-primary-text)] font-semibold text-sm uppercase tracking-wide mb-3">Leistungen</p>
        <h2>Was wir für Sie tun</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Heizung -->
        <a href="/leistungen/heizung-mayen/" class="group bg-white rounded-2xl p-8 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all">
          <div class="w-14 h-14 bg-[var(--color-primary)] bg-opacity-10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#E85000" class="group-hover:fill-white transition-colors" aria-hidden="true">
              <path d="M12 2c-4.97 0-9 4.03-9 9 0 2.39.88 4.57 2.33 6.25L4 20h5v-3H7.5C6.56 15.78 6 14.45 6 13c0-3.31 2.69-6 6-6s6 2.69 6 6c0 1.45-.56 2.78-1.5 3.78V20h5l-1.33-2.75C21.12 15.57 22 13.39 22 11c0-4.97-4.03-9-9-9zM9 21h6v-2H9v2z"/>
            </svg>
          </div>
          <h3 class="text-[var(--color-secondary)] mb-2">Heizung &amp; Wärmepumpe</h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-4">Moderne Heizungsanlagen, Wärmepumpen, Wartung und Reparatur. Energieeffizient und zukunftssicher.</p>
          <span class="text-[var(--color-primary-text)] font-semibold text-sm group-hover:underline">Mehr erfahren →</span>
        </a>

        <!-- Badsanierung -->
        <a href="/leistungen/badezimmersanierung-mayen/" class="group bg-white rounded-2xl p-8 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all">
          <div class="w-14 h-14 bg-[var(--color-secondary)] bg-opacity-10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#1A2733" class="group-hover:fill-white transition-colors" aria-hidden="true">
              <path d="M7 6h2v2H7V6zm4 0h2v2h-2V6zm4 0h2v2h-2V6zM5 4h14c1.1 0 2 .9 2 2v6H3V6c0-1.1.9-2 2-2zm16 9H3l1 9h16l1-9z"/>
            </svg>
          </div>
          <h3 class="text-[var(--color-secondary)] mb-2">Badsanierung</h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-4">Komplette Badezimmersanierung aus einer Hand — von der Planung bis zur Fertigstellung. Ihr Traumbad wartet.</p>
          <span class="text-[var(--color-primary-text)] font-semibold text-sm group-hover:underline">Mehr erfahren →</span>
        </a>

        <!-- Klimatechnik -->
        <a href="/leistungen/klimatechnik-mayen/" class="group bg-white rounded-2xl p-8 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all">
          <div class="w-14 h-14 bg-[var(--color-primary)] bg-opacity-10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#E85000" class="group-hover:fill-white transition-colors" aria-hidden="true">
              <path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z"/>
            </svg>
          </div>
          <h3 class="text-[var(--color-secondary)] mb-2">Klimatechnik</h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-4">Klimaanlagen, Split-Systeme, Planung und Wartung. Angenehmes Raumklima das ganze Jahr über.</p>
          <span class="text-[var(--color-primary-text)] font-semibold text-sm group-hover:underline">Mehr erfahren →</span>
        </a>

        <!-- Notdienst -->
        <a href="/leistungen/notdienst-reparaturen/" class="group bg-white rounded-2xl p-8 border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all">
          <div class="w-14 h-14 bg-[var(--color-secondary)] bg-opacity-10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#1A2733" class="group-hover:fill-white transition-colors" aria-hidden="true">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
            </svg>
          </div>
          <h3 class="text-[var(--color-secondary)] mb-2">Notdienst &amp; Reparaturen</h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-4">Heizung kaputt? Rohrbruch? Wir sind schnell vor Ort und helfen bei Notfällen jederzeit.</p>
          <span class="text-[var(--color-primary-text)] font-semibold text-sm group-hover:underline">Mehr erfahren →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. USPs — Alternating icon+text with orange accent lines -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-[var(--color-primary-text)] font-semibold text-sm uppercase tracking-wide mb-3">Warum Martini?</p>
        <h2>Vier gute Gründe für uns</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="flex gap-5 p-6 rounded-xl hover:bg-[var(--color-surface)] transition-colors">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            </div>
          </div>
          <div>
            <div class="w-12 h-1 bg-[var(--color-primary)] rounded mb-3"></div>
            <h3 class="text-[var(--color-secondary)] mb-2 text-lg">Persönlicher Ansprechpartner</h3>
            <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
              Kein Callcenter, kein anonymes Ticket-System. Sie sprechen direkt mit Sebastian Martini oder seinem Team — von Anfang bis Ende.
            </p>
          </div>
        </div>

        <div class="flex gap-5 p-6 rounded-xl hover:bg-[var(--color-surface)] transition-colors">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-[var(--color-secondary)] rounded-lg flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M13 2.05v2.02c3.95.49 7 3.85 7 7.93 0 3.21-1.81 6-4.72 7.28L13 17v5h5l-1.22-1.22C19.91 19.07 22 15.76 22 12c0-5.18-3.95-9.45-9-9.95zM11 2.05C5.95 2.55 2 6.82 2 12c0 3.76 2.09 7.07 5.22 8.78L6 22h5V2.05zM10 14H8V9.5l2 .58V14zm6 0h-2V9.5l2-.58V14z"/></svg>
            </div>
          </div>
          <div>
            <div class="w-12 h-1 bg-[var(--color-secondary)] rounded mb-3"></div>
            <h3 class="text-[var(--color-secondary)] mb-2 text-lg">Schnell &amp; zuverlässig</h3>
            <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
              Kurze Wege, schnelle Reaktion. Als lokaler Betrieb sind wir zügig bei Ihnen — keine langen Wartezeiten wie bei großen Ketten.
            </p>
          </div>
        </div>

        <div class="flex gap-5 p-6 rounded-xl hover:bg-[var(--color-surface)] transition-colors">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-[var(--color-primary)] rounded-lg flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M11.5 2C6.81 2 3 5.81 3 10.5S6.81 19 11.5 19h.5v3c4.86-2.34 8-7 8-11.5C20 5.81 16.19 2 11.5 2zm1 14.5h-2v-2h2v2zm0-4h-2c0-3.25 3-3 3-5 0-1.1-.9-2-2-2s-2 .9-2 2h-2c0-2.21 1.79-4 4-4s4 1.79 4 4c0 2.5-3 2.75-3 5z"/></svg>
            </div>
          </div>
          <div>
            <div class="w-12 h-1 bg-[var(--color-primary)] rounded mb-3"></div>
            <h3 class="text-[var(--color-secondary)] mb-2 text-lg">Ehrliche Beratung</h3>
            <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
              Wir empfehlen nur, was wirklich Sinn macht. Transparente Preise, keine versteckten Kosten. So haben es schon unsere Vorfahren gehalten.
            </p>
          </div>
        </div>

        <div class="flex gap-5 p-6 rounded-xl hover:bg-[var(--color-surface)] transition-colors">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-[var(--color-secondary)] rounded-lg flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
            </div>
          </div>
          <div>
            <div class="w-12 h-1 bg-[var(--color-secondary)] rounded mb-3"></div>
            <h3 class="text-[var(--color-secondary)] mb-2 text-lg">Meisterbetrieb mit Qualität</h3>
            <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
              Ausgebildeter SHK-Fachbetrieb mit Meistertitel. Alle Arbeiten werden sorgfältig und nach aktuellen Normen ausgeführt.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. BEWERTUNGEN — Dark section with white cards -->
  <section class="py-16 lg:py-24 bg-[var(--color-section-dark)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
