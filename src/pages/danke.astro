---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Vielen Dank! | Paul Martini Sanitär"
  description="Ihre Nachricht ist angekommen. Wir melden uns innerhalb eines Werktags."
>

  <section class="py-24 lg:py-32">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <!-- Success icon -->
      <div class="w-20 h-20 bg-[var(--color-primary)] rounded-full flex items-center justify-center mx-auto mb-8">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="white" aria-hidden="true">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
        </svg>
      </div>

      <h1 class="mb-4">Vielen Dank für Ihre Nachricht!</h1>
      <p class="text-[var(--color-text-muted)] text-lg mb-3 leading-relaxed">
        Ihre Anfrage ist bei uns eingegangen. Wir melden uns innerhalb eines Werktags bei Ihnen.
      </p>
      <p class="text-[var(--color-text-muted)] mb-10">
        Für dringende Anfragen erreichen Sie uns telefonisch unter <a href="tel:+4926514019589" class="text-[var(--color-primary-text)] font-semibold hover:underline">02651 4019589</a>.
      </p>

      <div class="bg-[var(--color-surface)] rounded-2xl p-6 border border-[var(--color-border)] mb-10 text-left">
        <h3 class="text-[var(--color-secondary)] mb-4 text-base font-semibold">Unsere Erreichbarkeit</h3>
        <div class="space-y-2 text-sm text-[var(--color-text-muted)]">
          <div class="flex items-center gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
            <span>Mo–Fr: 7:45–16:00 Uhr</span>
          </div>
          <div class="flex items-center gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#E85000" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            <a href="tel:+4926514019589" class="text-[var(--color-primary-text)] hover:underline">02651 4019589</a>
          </div>
        </div>
      </div>

      <a href="/" class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white px-8 py-4 rounded-xl font-bold text-base hover:bg-[var(--color-primary-dark)] transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
        Zur Startseite
      </a>
    </div>
  </section>

</BaseLayout>
